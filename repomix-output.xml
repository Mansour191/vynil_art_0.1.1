            <td :colspan="columns.length" class="text-center py-5">
              <slot name="empty">
                <div class="empty-state">
                  <i class="fas fa-folder-open fa-3x mb-3 opacity-20"></i>
                  <p class="text-muted">{{ emptyText || $t('noDataFound') }}</p>
