<script setup>
import { ref, computed, onMounted } from 'vue';
import { useRouter } from 'vue-router';
import PaymentService from '@/integration/services/PaymentService';
import OrderSyncService from '@/integration/services/OrderSyncService';
import NotificationService from '@/integration/services/NotificationService';

const router = useRouter();

// State
const cartItems = ref([]);
const isSubmitting = ref(false);
const form = ref({
  firstName: '',
  lastName: '',
  email: '',
  phone: '',
  address: '',
  wilaya: '16', // الجزائر العاصمة افتراضياً
  paymentMethod: 'cod',
});

const wilayas = [
  { id: '01', name: 'أدرار' }, { id: '02', name: 'الشلف' }, { id: '03', name: 'الأغواط' },
  { id: '04', name: 'أم البواقي' }, { id: '05', name: 'باتنة' }, { id: '06', name: 'بجاية' },
  { id: '07', name: 'بسكرة' }, { id: '08', name: 'بشار' }, { id: '09', name: 'البليدة' },
  { id: '10', name: 'البويرة' }, { id: '11', name: 'تمنراست' }, { id: '12', name: 'تبسة' },
  { id: '13', name: 'تلمسان' }, { id: '14', name: 'تيارت' }, { id: '15', name: 'تيزي وزو' },
  { id: '16', name: 'الجزائر' }, { id: '17', name: 'الجلفة' }, { id: '18', name: 'جيجل' },
  { id: '19', name: 'سطيف' }, { id: '20', name: 'سعيدة' }, { id: '21', name: 'سكيكدة' },
  { id: '22', name: 'سيدي بلعباس' }, { id: '23', name: 'عنابة' }, { id: '24', name: 'قالمة' },
  { id: '25', name: 'قسنطينة' }, { id: '26', name: 'المدية' }, { id: '27', name: 'مستغانم' },
  { id: '28', name: 'المسيلة' }, { id: '29', name: 'معسكر' }, { id: '30', name: 'ورقلة' },
  { id: '31', name: 'وهران' }, { id: '32', name: 'البيض' }, { id: '33', name: 'إليزي' },
  { id: '34', name: 'برج بوعريريج' }, { id: '35', name: 'بومرداس' }, { id: '36', name: 'الطارف' },
  { id: '37', name: 'تندوف' }, { id: '38', name: 'تيسمسيلت' }, { id: '39', name: 'الوادي' },
  { id: '40', name: 'خنشلة' }, { id: '41', name: 'سوق أهراس' }, { id: '42', name: 'تيبازة' },
  { id: '43', name: 'ميلة' }, { id: '44', name: 'عين الدفلى' }, { id: '45', name: 'النعامة' },
  { id: '46', name: 'عين تموشنت' }, { id: '47', name: 'غرداية' }, { id: '48', name: 'غليزان' }
];

// Computed
const subtotal = computed(() => cartItems.value.reduce((sum, item) => sum + item.price * item.quantity, 0));
const total = computed(() => subtotal.value);

// Methods
const loadCart = () => {
  const savedCart = localStorage.getItem('cart');
  if (savedCart) {
    cartItems.value = JSON.parse(savedCart);
  }
};

const prepareOrderData = () => {
  return {
    id: 'ORD-' + Date.now(),
    customer: `${form.value.firstName} ${form.value.lastName}`,
    customerEmail: form.value.email,
    customerPhone: form.value.phone,
    address: `${form.value.address}, ${form.value.wilaya}`,
    date: new Date().toISOString(),
    total: total.value,
    subtotal: subtotal.value,
    shipping: 0,
    tax: 0,
    status: 'pending',
    paymentMethod: form.value.paymentMethod,
    items: cartItems.value.map(item => ({
      sku: item.sku || 'SKU-' + item.id,
      name: item.name,
      quantity: item.quantity,
      price: item.price
    }))
  };
};

const finalizeOrder = (orderId, method) => {
  localStorage.removeItem('cart');
  
  // إشعار تأكيد الطلب
  NotificationService.success(
    'تم تأكيد طلبك', 
    `الطلب رقم ${orderId} قيد المعالجة الآن. شكراً لك!`
  );

  router.push({
    name: 'OrderSuccess',
    params: { orderId },
    query: { total: total.value, method }
  });
};

const processOnlinePayment = async (orderData) => {
  console.log('💳 البدء في معالجة الدفع الإلكتروني...');
  try {
    const paymentResult = await PaymentService.processCardPayment(orderData);
    if (paymentResult.success) {
      // مزامنة الطلب مع ERPNext فوراً بعد نجاح الدفع
      await OrderSyncService.syncSingleOrder(orderData);
      finalizeOrder(orderData.id, form.value.paymentMethod);
    }
  } catch (error) {
    alert('حدث خطأ أثناء معالجة الدفع: ' + error.message);
  }
};

const processCODOrder = async (orderData) => {
  console.log('📦 معالجة طلب الدفع عند الاستلام...');
  try {
    // في حالة COD، نقوم بالمزامنة مباشرة
    await OrderSyncService.syncSingleOrder(orderData);
    finalizeOrder(orderData.id, 'cod');
  } catch (error) {
    console.error('Error syncing COD order:', error);
    // حتى لو فشلت المزامنة، نعتبر الطلب ناجحاً محلياً ونخبر المستخدم
    finalizeOrder(orderData.id, 'cod');
  }
};

const submitOrder = async () => {
  if (cartItems.value.length === 0) return;
  
  isSubmitting.value = true;
  const orderData = prepareOrderData();
  
  try {
    if (form.value.paymentMethod === 'card') {
      await processOnlinePayment(orderData);
    } else {
      await processCODOrder(orderData);
    }
  } catch (error) {
    console.error('Error during order submission:', error);
  } finally {
    isSubmitting.value = false;
  }
};

// Lifecycle
onMounted(() => {
  loadCart();
  if (cartItems.value.length === 0) {
    router.push('/shop');
  }
});
</script>

