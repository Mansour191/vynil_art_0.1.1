}

.design-info-cell {
  display: flex;
  flex-direction: column;
}

.design-info-cell .design-name {
  color: white;
  font-weight: 600;
  margin-bottom: 3px;
}

.design-info-cell .design-artist {
  color: var(--gold-1);
  font-size: 0.8rem;
}

.category-badge {
