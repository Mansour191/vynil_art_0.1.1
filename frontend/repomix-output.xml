}

h1 { font-size: var(--text-4xl); }
h2 { font-size: var(--text-3xl); }
h3 { font-size: var(--text-2xl); }
h4 { font-size: var(--text-xl); }
h5 { font-size: var(--text-lg); }
h6 { font-size: var(--text-base); }

/* تحسين الأرقام */
.numbers, .amount, .price, .stat-value, .order-id {
  font-family: var(--font-numbers);
  font-weight: var(--font-medium);
  letter-spacing: 0.02em;
}

/* تحسين النصوص العربية */
[dir="rtl"] {
  font-family: var(--font-arabic);
}

/* تحسين النصوص الصغيرة */
.text-small, .text-muted, .meta-text {
  font-size: var(--text-sm);
  font-weight: var(--font-normal);
  color: var(--text-dim);
}

.text-xs {
  font-size: var(--text-xs);
}

/* تحسين الروابط */
a {
  font-weight: var(--font-medium);
  transition: var(--transition-soft);
}

/* تحسين الأزرار */
button, .btn {
  font-weight: var(--font-semibold);
  letter-spacing: 0.3px;
}

/* تحسين الجداول */
table {
  font-size: var(--text-sm);
}

table th {
  font-weight: var(--font-semibold);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

table td {
  font-weight: var(--font-normal);
}

/* تحسين النماذج */
input, select, textarea {
  font-family: var(--font-primary);
  font-size: var(--text-sm);
}

/* تأثيرات الخط */
.gradient-text {
  background: var(--gold-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: var(--font-bold);
}

/* تحسينات للشاشات الصغيرة */
@media (max-width: 768px) {
  :root {
    --text-4xl: 2rem;
    --text-3xl: 1.75rem;
    --text-2xl: 1.5rem;
    --text-xl: 1.25rem;
  }
}

/* تأكيد أن Font Awesome يعمل بشكل صحيح */
.fa,
.fas,
.far,
.fal,
.fab,
.mdi {
  font-family: inherit;
}

/* أيقونات احتياطية إذا فشل تحميل Font Awesome */
i:not([class*="fa"]):not([class*="mdi"]) {
  font-family: 'Font Awesome 6 Free', 'Font Awesome 6 Brands', 'Material Design Icons', sans-serif;
}

/* إعادة تعيين أيقونات Font Awesome في الظلام */
body:not(.light-mode) .fa,
body:not(.light-mode) .fas,
body:not(.light-mode) .far {
