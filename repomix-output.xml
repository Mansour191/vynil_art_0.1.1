          <div class="design-footer">
            <div class="design-price">{{ design.price }} ر.س</div>
            <div class="design-usage">
              <i class="fa-solid fa-shopping-cart"></i>
              <span>{{ design.usageCount }} مستخدم</span>
            </div>
          </div>
        </div>
      </div>

