  --shadow-sm: 0 4px 12px rgba(0, 0, 0, 0.4);
  --shadow-md: 0 8px 24px rgba(0, 0, 0, 0.5);
  --shadow-lg: 0 16px 48px rgba(0, 0, 0, 0.6);
  --shadow-xl: 0 24px 64px rgba(0, 0, 0, 0.7);
  --shadow-gold: 0 8px 32px rgba(212, 175, 55, 0.3);
  --shadow-gold-strong: 0 12px 48px rgba(212, 175, 55, 0.5);
  
  /* التدرجات */
  --gradient-dark: linear-gradient(145deg, #0a0c14 0%, #03050a 100%);
  --gradient-card: linear-gradient(145deg, #1a1f2e 0%, #11141f 100%);
  --gradient-card-hover: linear-gradient(145deg, #222837 0%, #1a1f2e 100%);
  
  /* أنيميشن */
  --transition-smooth: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  --transition-soft: all 0.3s ease;
  --transition-bounce: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

/* تأثير الخلفية المتحركة */
body::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: 
    radial-gradient(circle at 20% 30%, rgba(212, 175, 55, 0.05) 0%, transparent 30%),
    radial-gradient(circle at 80% 70%, rgba(212, 175, 55, 0.05) 0%, transparent 30%),
    repeating-linear-gradient(45deg, rgba(212, 175, 55, 0.02) 0px, rgba(212, 175, 55, 0.02) 1px, transparent 1px, transparent 10px);
  pointer-events: none;
  z-index: -1;
  animation: backgroundShift 20s ease infinite alternate;
}

@keyframes backgroundShift {
  0% { transform: scale(1) rotate(0deg); opacity: 0.5; }
  50% { transform: scale(1.05) rotate(0.5deg); opacity: 0.8; }
  100% { transform: scale(1) rotate(1deg); opacity: 0.5; }
}

/* تأثير الجسيمات المتحركة */
.particles {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1;
}

.particle {
  position: absolute;
  width: 2px;
  height: 2px;
  background: rgba(212, 175, 55, 0.3);
  border-radius: 50%;
  animation: float 20s infinite linear;
}

@keyframes float {
  from {
    transform: translateY(100vh) translateX(0);
    opacity: 0;
  }
  50% {
    opacity: 0.8;
  }
  to {
    transform: translateY(-100px) translateX(100px);
    opacity: 0;
  }
}

/* src/assets/theme.css - تحديث الخطوط */


/* تطبيق الخط الأساسي */
* {
  font-family: var(--font-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

body {
  font-family: var(--font-primary);
  font-size: var(--text-base);
  font-weight: var(--font-normal);
  line-height: var(--leading-normal);
