<script setup>
import { ref, computed, watch, onMounted, getCurrentInstance } from 'vue';
import { useRoute, useRouter } from 'vue-router';
import { useStore } from 'vuex';
import { useI18n } from 'vue-i18n';
import ProductCard from '@/components/ProductCard.vue';
import ProductReviews from '@/components/ProductReviews.vue';
import ProductFAQ from '@/components/ProductFAQ.vue';
import ProductImageGallery from '@/components/ProductImageGallery.vue';
import ProductSpecs from '@/components/ProductSpecs.vue';
import LoadingSkeleton from '@/components/LoadingSkeleton.vue';
import Breadcrumbs from '@/components/common/Breadcrumbs.vue';
import ERPNextService from '@/integration/services/ERPNextService';

const route = useRoute();
const router = useRouter();
const store = useStore();
const { t, locale } = useI18n();
const { proxy } = getCurrentInstance();

// State
const product = ref(null);
const loading = ref(true);
const error = ref(null);
const width = ref(100);
const height = ref(100);
const quantity = ref(1);
const selectedColor = ref('');
const selectedQuality = ref('standard');
const isFavorite = ref(false);
const lightbox = ref(false);
const submitting = ref(false);
const relatedProducts = ref([]);

// Computed
const isAuthenticated = computed(() => store.getters['auth/isAuthenticated']);
const avgRating = computed(() => store.getters['reviews/getAverageRating'](product.value?.id.toString()) || product.value?.rating || 0);
const reviewsCount = computed(() => store.getters['reviews/getReviewsCount'](product.value?.id.toString()) || product.value?.reviews || 0);
const mainImage = computed(() => product.value?.images[0] || '');

const categoryIcon = computed(() => {
  const icons = { furniture: 'fa-sofa', doors: 'fa-door-open', walls: 'fa-paint-roller', ceilings: 'fa-arrow-up', tiles: 'fa-border-all', kitchens: 'fa-utensils', cars: 'fa-car' };
  return icons[product.value?.category] || 'fa-question';
});

const area = computed(() => ((width.value / 100) * (height.value / 100)).toFixed(2));
const calculatedPrice = computed(() => {
  if (!product.value) return 0;
  const areaVal = parseFloat(area.value) || 1;
  return (product.value.price * areaVal) * quantity.value;
});

// Methods
const formatPrice = (price) => new Intl.NumberFormat(locale.value, { style: 'currency', currency: 'DZD', minimumFractionDigits: 0 }).format(price);

const loadProduct = async (id) => {
  loading.value = true;
  error.value = null;
  try {
    const response = await ERPNextService.getProduct(id);
    if (response.success) {
      const data = response.data;
      // تحويل بيانات ERPNext لتناسب واجهتنا
      product.value = {
        id: data.item_code,
        title: data.item_name,
        description: data.description || 'تصميم فينيل عالي الجودة مخصص حسب الطلب.',
        price: data.standard_rate || 2500,
        category: data.item_group?.toLowerCase() || 'walls',
        categoryKey: data.item_group?.toLowerCase() || 'walls',
        images: [
          data.image || `https://images.unsplash.com/photo-1513519245088-0e12902e5a38?q=80&w=800&auto=format&fit=crop`,
          'https://images.unsplash.com/photo-1524758631624-e2822e304c36?q=80&w=800&auto=format&fit=crop',
          'https://images.unsplash.com/photo-1505691938895-1758d7eaa511?q=80&w=800&auto=format&fit=crop'
        ],
        specs: [
          { icon: 'fa-weight', label: 'weight', value: 'خفيف الوزن' },
          { icon: 'fa-layer-group', label: 'material', value: 'Premium Vinyl' },
          { icon: 'fa-tint-slash', label: 'durability', value: 'مقاوم للماء' },
          { icon: 'fa-sun', label: 'durability', value: 'مقاوم للشمس' }
        ],
        translations: {
          ar: { title: data.item_name, excerpt: data.description || 'تصميم فينيل مخصص عالي الجودة لمساحتك العصرية.' },
          en: { title: data.item_name_en || data.item_name, excerpt: data.description_en || 'High-quality custom vinyl design for your modern space.' },
          fr: { title: data.item_name_fr || data.item_name, excerpt: data.description_fr || 'Design en vinyle personnalisé de haute qualité pour votre espace moderne.' }
        },
        rating: 4.8,
        reviews: 24,
        onSale: true,
        originalPrice: (data.standard_rate || 2500) * 1.2
      };
      
      // تحديث SEO
      proxy.$seo({
        title: product.value.title,
        description: product.value.description,
        image: product.value.images[0]
      });

      loadRelatedProducts();
    } else {
      throw new Error(response.message);
    }
  } catch (err) {
    error.value = err.message;
  } finally {
    loading.value = false;
  }
};

const loadRelatedProducts = async () => {
  try {
    const res = await ERPNextService.getProducts();
    if (res.success) {
      relatedProducts.value = res.data.slice(0, 4).map(p => ({
        id: p.item_code,
        title: p.item_name,
        price: p.standard_rate,
        image: p.image || 'https://images.unsplash.com/photo-1513519245088-0e12902e5a38?q=80&w=400&auto=format&fit=crop',
        translations: {
          ar: { title: p.item_name },
          en: { title: p.item_name_en || p.item_name }
        }
      }));
    }
  } catch (e) { console.error(e); }
};

const addToCart = () => {
  if (!isAuthenticated.value) { store.dispatch('ui/toggleLoginModal', true); return; }
  const item = { 
    id: product.value.id, 
    title: product.value.translations?.[locale.value]?.title || product.value.title, 
    price: calculatedPrice.value, 
    image: product.value.images[0], 
    quantity: quantity.value, 
    options: { width: width.value, height: height.value } 
  };
  store.dispatch('cart/addToCart', item);
  
  // تغذية راجعة للمستخدم
  submitting.value = true;
  setTimeout(() => {
    submitting.value = false;
    // يمكن هنا التوجيه للسلة أو إظهار توست
  }, 500);
};

const toggleFavorite = () => {
  if (!isAuthenticated.value) { store.dispatch('ui/toggleLoginModal', true); return; }
  isFavorite.value = !isFavorite.value;
  store.dispatch('wishlist/toggleWishlist', product.value);
};

onMounted(() => { if (route.params.id) loadProduct(route.params.id); });
watch(() => route.params.id, (id) => id && loadProduct(id));
</script>

