<script setup>
import { ref, reactive, computed } from 'vue';
import { useI18n } from 'vue-i18n';
import zxcvbn from 'zxcvbn';
import BaseModal from '@/components/common/BaseModal.vue';

const props = defineProps({
  value: Boolean,
});

const emit = defineEmits(['input', 'switch-to-login', 'social-signup']);
const { t } = useI18n();

const form = reactive({
  name: '',
  email: '',
  password: '',
  confirmPassword: '',
  acceptTerms: false,
});

const passwordStrength = reactive({
  score: 0,
  text: '',
});

const loading = ref(false);
const error = ref(null);

const isFormValid = computed(() => {
  return (
    form.name &&
    form.email &&
    form.password &&
    form.confirmPassword &&
    form.password === form.confirmPassword &&
    form.acceptTerms &&
    form.password.length >= 8
  );
});

const checkPasswordStrength = () => {
  if (form.password) {
    const result = zxcvbn(form.password);
    passwordStrength.score = result.score;

    const strengthTexts = {
      0: t('weak'),
      1: t('weak'),
      2: t('medium'),
      3: t('strong'),
      4: t('veryStrong'),
    };
    passwordStrength.text = strengthTexts[result.score];
  } else {
    passwordStrength.score = 0;
    passwordStrength.text = '';
  }
};

const signupWithSocial = (platform) => {
  emit('social-signup', platform);
  console.log(`Signup with ${platform}`);
  alert(`سيتم تفعيل تسجيل الدخول بـ ${platform} قريباً`);
};

const handleSignup = async () => {
  if (!isFormValid.value) return;

  loading.value = true;
  error.value = null;

  try {
    await new Promise((resolve) => setTimeout(resolve, 1500));
    console.log('Signup data:', form);
    alert(t('signupSuccess'));
    close();
    emit('switch-to-login');
  } catch (err) {
    error.value = err.message || t('signupError');
  } finally {
    loading.value = false;
  }
};

const close = () => {
  emit('input', false);
  resetForm();
};

const switchToLogin = () => {
  close();
  emit('switch-to-login');
};

const resetForm = () => {
  form.name = '';
  form.email = '';
  form.password = '';
  form.confirmPassword = '';
  form.acceptTerms = false;
  passwordStrength.score = 0;
  passwordStrength.text = '';
  error.value = null;
};
</script>

