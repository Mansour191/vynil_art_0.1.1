}
.category-badge.doors {
  background: rgba(255, 152, 0, 0.2);
  color: #ff9800;
  border: 1px solid #ff9800;
}
.category-badge.ceilings {
  background: rgba(156, 39, 176, 0.2);
  color: #9c27b0;
  border: 1px solid #9c27b0;
}
.category-badge.tiles {
  background: rgba(233, 30, 99, 0.2);
