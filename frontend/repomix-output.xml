defineEmits([
  'sort',
  'view',
  'edit',
  'toggle-select',
  'toggle-select-all',
  'toggle-menu',
  'update-status',
]);

const formatAmount = (amount) => CurrencyService.formatAmount(amount);

const getStatusText = (status) => {
  const map = {
