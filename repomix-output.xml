      borderColor: '#2ecc71',
      borderDash: [5, 5],
      backgroundColor: 'transparent',
      tension: 0.4
    }
  ]
};

const chartOptions = {
  responsive: true,
  maintainAspectRatio: false,
  plugins: { legend: { labels: { color: '#ffffff' } } },
