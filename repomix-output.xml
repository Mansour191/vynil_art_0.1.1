  }

  // الحصول على سجل البريد
  getEmailLogs(limit = 20) {
    const logs = JSON.parse(localStorage.getItem('emailLogs') || '[]');
    return logs.slice(0, limit);
  }

  // تحديث إعدادات البريد
  updateConfig(newConfig) {
    this.config = { ...this.config, ...newConfig };
    this.saveConfig();
  }
}

