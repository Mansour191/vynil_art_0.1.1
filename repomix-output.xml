<template>
  <div
    class="product-sync-test"
    style="padding: 30px; max-width: 1200px; margin: 0 auto; direction: rtl"
  >
    <h1 style="color: #d4af37; text-align: center">🔄 اختبار مزامنة المنتجات مع ERPNext</h1>

