<file path="src/store/modules/auth.js">
import zxcvbn from 'zxcvbn';

export default {
  namespaced: true,
  state: {
    user: (() => {
      try {
        const saved = localStorage.getItem('currentUser') || sessionStorage.getItem('currentUser');
        return saved ? JSON.parse(saved) : null;
      } catch (e) {
        return null;
      }
    })(),
    loading: false,
    error: null,
  },
  mutations: {
    SET_USER(state, user) {
      state.user = user;
    },
    SET_LOADING(state, loading) {
      state.loading = loading;
    },
    SET_ERROR(state, error) {
      state.error = error;
    },
    CLEAR_ERROR(state) {
      state.error = null;
    },
  },
  actions: {
    async login({ commit }, { email, password, remember }) {
      commit('SET_LOADING', true);
      commit('CLEAR_ERROR');

      try {
        await new Promise((resolve) => setTimeout(resolve, 1000));

        if (email && password) {
          const user = {
            email,
            name: email.split('@')[0],
            passwordStrength: zxcvbn(password).score,
          };

          if (remember) {
            localStorage.setItem('currentUser', JSON.stringify(user));
          } else {
            sessionStorage.setItem('currentUser', JSON.stringify(user));
          }

          commit('SET_USER', user);
          
          // دمج السلة والمفضلة عند تسجيل الدخول
          dispatch('cart/mergeCart', null, { root: true });
          dispatch('wishlist/mergeWishlist', null, { root: true });
          
          return { success: true };
        } else {
          throw new Error('Invalid credentials');
        }
      } catch (error) {
        commit('SET_ERROR', error.message);
        return { success: false, error: error.message };
      } finally {
        commit('SET_LOADING', false);
      }
    },

    async signup({ commit }, userData) {
      commit('SET_LOADING', true);
      commit('CLEAR_ERROR');

      try {
        await new Promise((resolve) => setTimeout(resolve, 1000));

        // استخدام userData
        console.log('Signup data:', userData);

        // محاكاة تسجيل ناجح
        const user = {
          email: userData.email,
          name: userData.name,
        };

        return { success: true, user };
      } catch (error) {
        commit('SET_ERROR', error.message);
        return { success: false, error: error.message };
      } finally {
        commit('SET_LOADING', false);
      }
    },

    logout({ commit, dispatch }) {
      localStorage.removeItem('currentUser');
      sessionStorage.removeItem('currentUser');
      commit('SET_USER', null);
      
      // اختيارياً: يمكن مسح السلة والمفضلة عند تسجيل الخروج إذا كان هذا هو السلوك المطلوب
      // أو تركها في localStorage كما هو مطلوب في السؤال
      console.log('User logged out. Cart and Wishlist remain in localStorage.');
    },
  },
  getters: {
    isAuthenticated: (state) => !!state.user,
    currentUser: (state) => state.user,
    loading: (state) => state.loading,
    error: (state) => state.error,
  },
};
</file>

