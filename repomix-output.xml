        <h4>لا توجد تصاميم</h4>
        <p>لم يتم العثور على تصاميم تطابق معايير البحث</p>
        <button class="btn-primary" @click="resetFilters">
          <i class="fa-solid fa-undo"></i> إعادة تعيين الفلاتر
        </button>
      </div>
    </div>

