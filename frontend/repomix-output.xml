            >
              <i class="fa-solid fa-check"></i>
            </button>

            <button
              v-if="alert.actionable"
              class="action-btn view"
              @click="handleAction(alert)"
              title="عرض التفاصيل"
            >
              <i class="fa-solid fa-eye"></i>
            </button>

