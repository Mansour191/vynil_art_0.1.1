      const result = await this.mutateGraphQL(CREATE_PAYMENT, {
        input: paymentData
      });
      
      // Clear relevant caches
      this.clearCache('payments_');
      this.clearCache(`order_${paymentData.orderId}`);
      
      return result;
    } catch (error) {
