        <!-- Load More Button -->
        <div v-if="hasMore" class="load-more">
          <button class="load-more-btn" @click="loadMore">
            <i class="fa-solid fa-plus"></i>
            {{ $t('loadMore') }}
          </button>
        </div>
      </div>
    </section>

    <!-- Lightbox -->
    <div v-if="lightbox.show" class="lightbox" @click.self="closeLightbox">
