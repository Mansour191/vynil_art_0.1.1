<template>
  <div class="chatbot-root">
    <button class="chat-fab" @click="open = !open">
      <i class="fa-solid fa-comments"></i>
    </button>

    <div v-if="open" class="chat-window">
      <div class="chat-header">
        <strong>Paclos Assistant</strong>
        <button class="close-btn" @click="open = false"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="chat-body">
        <div v-for="(msg, idx) in messages" :key="idx" :class="['msg', msg.role]">
          {{ msg.text }}
        </div>
      </div>
      <form class="chat-input" @submit.prevent="sendMessage">
        <input v-model="input" type="text" placeholder="اسأل عن التركيب أو أنواع الفينيل..." />
        <button :disabled="loading">{{ loading ? '...' : 'إرسال' }}</button>
      </form>
    </div>
  </div>
</template>

<script setup>
import { ref } from 'vue';
import ChatService from '@/integration/services/ChatService';

const open = ref(false);
const loading = ref(false);
const input = ref('');
const messages = ref([
  { role: 'bot', text: 'مرحباً، أنا مساعد Paclos. كيف يمكنني مساعدتك اليوم؟' },
]);

const sendMessage = async () => {
  const text = input.value.trim();
  if (!text || loading.value) return;
  messages.value.push({ role: 'user', text });
  input.value = '';
  loading.value = true;
  try {
    const data = await ChatService.ask(text);
    messages.value.push({ role: 'bot', text: data.answer || 'لم أتمكن من الإجابة الآن.' });
  } catch (e) {
    messages.value.push({ role: 'bot', text: 'الخدمة غير متاحة حالياً، حاول لاحقاً.' });
  } finally {
    loading.value = false;
  }
};
</script>

