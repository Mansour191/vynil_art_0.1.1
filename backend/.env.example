DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# GraphQL Configuration
GRAPHENE_DEBUG=False  # Set to False in production to disable GraphQL Playground

ERPNEXT_BASE_URL=https://your-erpnext-domain.com
ERPNEXT_API_KEY=your_server_side_api_key
ERPNEXT_API_SECRET=your_server_side_api_secret
ERPNEXT_TIMEOUT=30

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
KB_DIR=backend/knowledge_base

# Redis Configuration (for WebSocket and background tasks)
REDIS_URL=redis://127.0.0.1:6379/0

# WebSocket Configuration
WEBSOCKET_PROTOCOL=ws
WEBSOCKET_HOST=localhost
WEBSOCKET_PORT=8000
