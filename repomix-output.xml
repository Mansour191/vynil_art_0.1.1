          <div v-if="form.password" class="password-strength">
            <div class="strength-bars">
              <div
                v-for="n in 4"
                :key="n"
                class="strength-bar"
                :class="{
                  active: n <= passwordStrength.score,
                  weak: passwordStrength.score <= 1,
                  medium: passwordStrength.score === 2,
