<template>
  <BaseModal 
    :modelValue="value" 
    @update:modelValue="close"
    :title="$t('loginTitle')"
    size="md"
  >
    <template #header>
      <h3 class="modal-header-title">
        <i class="fas fa-user-circle"></i>
        {{ $t('loginTitle') }}
      </h3>
    </template>

    <div class="modal-body-content">
      <!-- رسائل الخطأ -->
      <div v-if="error" class="error-message">
        <i class="fas fa-exclamation-circle"></i>
        {{ error }}
      </div>

      <!-- رسالة النجاح -->
      <div v-if="success" class="success-message">
        <i class="fas fa-check-circle"></i>
        {{ success }}
      </div>

      <!-- نموذج تسجيل الدخول التقليدي -->
      <form @submit.prevent="handleLogin" v-if="!loading">
        <div class="form-group">
          <label>
            <i class="fas fa-envelope"></i>
            {{ $t('email') }}
          </label>
          <input type="email" v-model="form.email" :placeholder="$t('email')" required />
        </div>

        <div class="form-group">
          <label>
            <i class="fas fa-lock"></i>
            {{ $t('password') }}
          </label>
          <input type="password" v-model="form.password" :placeholder="$t('password')" required />
        </div>

        <div class="form-options">
          <label class="remember-me">
            <input type="checkbox" v-model="remember" />
            <span>{{ $t('rememberMe') }}</span>
          </label>
          <a href="#" @click.prevent="forgotPassword">{{ $t('forgotPassword') }}</a>
        </div>

        <button type="submit" class="submit-btn" :disabled="loading">
          <i class="fas fa-sign-in-alt"></i>
          <span v-if="!loading">{{ $t('login') }}</span>
          <span v-else><i class="fas fa-spinner fa-spin"></i> {{ $t('loading') }}</span>
        </button>
      </form>

      <!-- خط فاصل -->
      <div class="divider">
        <span class="divider-text">{{ $t('orContinueWith') }}</span>
      </div>

      <!-- أزرار تسجيل الدخول الاجتماعي -->
      <div class="social-login">
        <button class="social-btn google" @click="loginWithGoogle" :disabled="loading">
          <i class="fab fa-google"></i>
          <span>{{ $t('continueWithGoogle') }}</span>
        </button>

        <button class="social-btn facebook" @click="loginWithFacebook" :disabled="loading">
          <i class="fab fa-facebook-f"></i>
          <span>{{ $t('continueWithFacebook') }}</span>
        </button>

        <button class="social-btn microsoft" @click="loginWithMicrosoft" :disabled="loading">
          <i class="fab fa-microsoft"></i>
          <span>{{ $t('continueWithMicrosoft') }}</span>
        </button>
      </div>

      <div class="modal-footer-custom">
        <p>{{ $t('noAccount') }}</p>
        <a href="#" @click.prevent="$emit('switch-to-signup')">{{ $t('createAccount') }}</a>
      </div>
    </div>
  </BaseModal>
</template>

<script setup>
import { ref, reactive } from 'vue';
import { useAuthStore } from '@/store/auth';
import { useRouter } from 'vue-router';
import { useI18n } from 'vue-i18n';
import { auth, googleProvider, facebookProvider, microsoftProvider } from '@/firebase';
import { signInWithEmailAndPassword, signInWithPopup } from 'firebase/auth';
import BaseModal from '@/components/common/BaseModal.vue';

const props = defineProps({
  value: Boolean,
});

const emit = defineEmits(['input', 'switch-to-signup']);
const authStore = useAuthStore();
const router = useRouter();
const { t } = useI18n();

const form = reactive({
  email: '',
  password: '',
});
const remember = ref(false);
const loading = ref(false);
const error = ref(null);
const success = ref(null);

const handleSuccessfulLogin = (user, role = 'customer') => {
  authStore.setUser(user, 'dummy-token', role);
  success.value = t('loginSuccess');
  
  setTimeout(() => {
    close();
    if (role === 'admin') router.push('/dashboard');
    else if (role === 'investor') router.push('/investor');
    else router.push('/');
  }, 1000);
};

const handleLogin = async () => {
  loading.value = true;
  error.value = null;
  try {
    let role = 'customer';
    if (form.email.includes('admin')) role = 'admin';
    if (form.email.includes('investor')) role = 'investor';

    const result = await signInWithEmailAndPassword(auth, form.email, form.password);
    const user = {
      email: result.user.email,
      name: result.user.displayName || form.email.split('@')[0],
      photoURL: result.user.photoURL,
    };
    handleSuccessfulLogin(user, role);
  } catch (err) {
    error.value = t('invalidEmailOrPassword');
  } finally {
    loading.value = false;
  }
};

const loginWithGoogle = async () => {
  loading.value = true;
  try {
    const result = await signInWithPopup(auth, googleProvider);
    handleSuccessfulLogin({
      email: result.user.email,
      name: result.user.displayName,
      photoURL: result.user.photoURL,
    });
  } catch (err) {
    error.value = t('loginError');
  } finally {
    loading.value = false;
  }
};

const close = () => {
  emit('input', false);
  form.email = '';
  form.password = '';
  error.value = null;
  success.value = null;
};
</script>

