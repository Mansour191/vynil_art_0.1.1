  align-items: center;
  gap: 2px;
}

.rating-display i {
  color: var(--text-dim);
  font-size: 0.8rem;
}

.rating-display i.filled {
  color: var(--gold-1);
}

.rating-display span {
  margin-right: 5px;
  color: var(--text-dim);
  font-size: 0.8rem;
}

.status-badge {
