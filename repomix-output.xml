                        ref="fileInput"
                        @change="handleImageUpload"
                        accept="image/*"
                        style="display: none"
                      />
                    </div>
                  </div>
                </div>
              </div>

              <div class="form-actions">
                <button type="button" class="btn-cancel" @click="closeDesignModal">إلغاء</button>
                <button type="submit" class="btn-save">
                  <i class="fa-solid fa-save"></i> {{ isEditing ? 'تحديث' : 'إضافة' }}
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
