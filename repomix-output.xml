<script setup>
import { ref, computed, onMounted, onUnmounted } from 'vue';
import { useAuthStore } from '@/store/auth';
import { useStore } from 'vuex';
import { useI18n } from 'vue-i18n';
import NotificationsDropdown from './NotificationsDropdown.vue';
import LanguageSwitcher from './common/LanguageSwitcher.vue';

const props = defineProps({
  isDarkMode: {
    type: Boolean,
    default: false,
  },
});

const emit = defineEmits(['toggle-mobile-menu', 'open-login', 'change-language', 'toggle-theme']);

const authStore = useAuthStore();
const store = useStore();

// State
const activeMobileDropdown = ref(null);

// Computed
const isAuthenticated = computed(() => authStore.isAuthenticated);
const currentUser = computed(() => authStore.user);
const wishlistCount = computed(() => store.getters['user/wishlistCount']);

const userDisplayName = computed(() => {
  return currentUser.value?.name?.split(' ')[0] || '';
});

// Methods
const handleLoginClick = () => {
  console.log('✅ Header: تم النقر على زر تسجيل الدخول');
  emit('open-login');
};

const changeLanguage = (lang) => {
  emit('change-language', lang);
};

const toggleTheme = () => {
  emit('toggle-theme');
};

const toggleMobileDropdown = (id) => {
  activeMobileDropdown.value = activeMobileDropdown.value === id ? null : id;
};
</script>

