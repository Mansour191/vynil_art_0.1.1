        description: 'ملصق باب بتصميم خشبي كلاسيكي يضفي مظهراً فخماً على الأبواب الداخلية.',
        createdAt: '2024-01-20',
      },
      {
        id: 3,
        name: 'إطار سيارة رياضي أحمر',
        shortDesc: 'إطارات جانبية لامعة',
        category: 'cars',
        price: 120,
        stock: 0,
        active: false,
        featured: false,
        rating: 4.8,
        reviews: 5,
        sales: 8,
        sku: 'CAR-003',
        image: 'https://images.unsplash.com/photo-1580273916550-e323be2ae537?w=200',
        description: 'إطارات جانبية للسيارات بتصميم رياضي لامع، تضفي مظهراً رياضياً على سيارتك.',
        createdAt: '2024-02-01',
      },
    ],
    loading: false,
    error: null,
    syncProgress: 0,
  },

  mutations: {
    SET_PRODUCTS(state, products) {
      state.products = products;
    },
    SET_LOADING(state, status) {
      state.loading = status;
    },
    SET_ERROR(state, error) {
      state.error = error;
    },
    ADD_PRODUCT(state, product) {
      state.products.unshift(product);
    },
    UPDATE_PRODUCT(state, product) {
      const index = state.products.findIndex((p) => p.id === product.id);
      if (index !== -1) {
        state.products.splice(index, 1, product);
      }
    },
    DELETE_PRODUCT(state, id) {
      state.products = state.products.filter((p) => p.id !== id);
    },
    SET_SYNC_PROGRESS(state, progress) {
      state.syncProgress = progress;
    },
  },

  actions: {
    async fetchProducts({ commit }) {
      commit('SET_LOADING', true);
      try {
        // محاكاة جلب البيانات
        await new Promise((resolve) => setTimeout(resolve, 500));
        // يمكن جلب البيانات من localStorage أو API
        const saved = localStorage.getItem('products');
        if (saved) {
          commit('SET_PRODUCTS', JSON.parse(saved));
        }
      } catch (e) {
        commit('SET_ERROR', e.message);
      } finally {
        commit('SET_LOADING', false);
      }
    },

    async saveProduct({ commit, state }, product) {
      // التحقق من صحة البيانات
      if (!product.name || product.price <= 0) {
        throw new Error('بيانات المنتج غير صالحة. يرجى التأكد من الاسم والسعر.');
      }

      if (product.id) {
        commit('UPDATE_PRODUCT', product);
      } else {
        product.id = Date.now();
        product.createdAt = new Date().toISOString().split('T')[0];
        commit('ADD_PRODUCT', product);
      }
      localStorage.setItem('products', JSON.stringify(state.products));
    },

    async deleteProduct({ commit, state }, id) {
      commit('DELETE_PRODUCT', id);
      localStorage.setItem('products', JSON.stringify(state.products));
    },

    async syncAllWithERPNext({ commit }) {
      commit('SET_LOADING', true);
      try {
        const result = await ProductSyncService.syncProducts((progress) => {
          commit('SET_SYNC_PROGRESS', progress);
        });
        // تحديث المنتجات بعد المزامنة
        // commit('SET_PRODUCTS', result.products);
        return result;
      } catch (e) {
        commit('SET_ERROR', e.message);
        throw e;
      } finally {
        commit('SET_LOADING', false);
        commit('SET_SYNC_PROGRESS', 0);
      }
    },
  },

  getters: {
    allProducts: (state) => state.products,
    productCount: (state) => state.products.length,
    lowStockProducts: (state) => state.products.filter((p) => p.stock < 10),
    getProductById: (state) => (id) => state.products.find((p) => p.id === id),
  },
};
