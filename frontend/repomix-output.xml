  // Design Operations using GraphQL
  async createDesign(designData) {
    try {
      const result = await this.mutateGraphQL(CREATE_DESIGN, {
        input: designData
      });
      
      // Clear designs cache
      this.cache.delete('my_designs');
      return result;
    } catch (error) {
      console.error('Error creating design:', error);
      throw error;
