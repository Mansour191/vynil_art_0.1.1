import { defineStore } from 'pinia';

export const useAuthStore = defineStore('auth', {
  state: () => ({
    user: (() => {
      try {
        const saved = localStorage.getItem('user');
        return saved ? JSON.parse(saved) : null;
      } catch (e) {
        return null;
      }
    })(),
    token: localStorage.getItem('token') || null,
    role: localStorage.getItem('role') || 'guest', // guest, customer, admin, investor
  }),
  getters: {
    isAuthenticated: (state) => !!state.token,
    isAdmin: (state) => state.role === 'admin',
    isInvestor: (state) => state.role === 'investor',
    isCustomer: (state) => state.role === 'customer',
  },
  actions: {
    setUser(userData, token, role) {
      this.user = userData;
      this.token = token;
      this.role = role;
      localStorage.setItem('user', JSON.stringify(userData));
      localStorage.setItem('token', token);
      localStorage.setItem('role', role);
    },
    async login(email, password) {
      // التحقق من بيانات المدير (admin/admin)
      if (email === 'admin' && password === 'admin') {
        const adminUser = {
          email: 'admin@vinylart.com',
          name: 'المدير العام',
          role: 'admin'
        };
        this.setUser(adminUser, 'admin-token-123', 'admin');
        return { success: true, role: 'admin' };
      }

      // التحقق من بيانات الممول (investor/investor)
      if (email === 'investor' && password === 'investor') {
        const investorUser = {
          email: 'investor@vinylart.com',
          name: 'الممول الاستراتيجي',
          role: 'investor'
        };
        this.setUser(investorUser, 'investor-token-456', 'investor');
        return { success: true, role: 'investor' };
      }
      
      // هنا يمكن إضافة منطق Firebase لاحقاً
      throw new Error('بيانات الدخول غير صحيحة');
    },
    logout() {
      this.user = null;
      this.token = null;
      this.role = 'guest';
      localStorage.removeItem('user');
      localStorage.removeItem('token');
      localStorage.removeItem('role');
    },
  },
});
