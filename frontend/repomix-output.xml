              <h2 class="text-h4 font-weight-bold text-primary mb-2">
                {{ $t('verifyEmailTitle') || 'تفعيل البريد الإلكتروني' }}
              </h2>
            </div>

            <!-- Loading State -->
            <div v-if="loading" class="text-center py-8">
              <v-progress-circular 
                indeterminate 
                color="primary" 
                size="48"
                class="mb-4"
              />
